# Ports
FRONTEND_PORT=5173
BACKEND_PORT=8000

# Frontend build-time API base.
# Keep localhost:5173 so browser requests stay same-origin and nginx forwards to backend.
VITE_API_URL=http://localhost:5173

# Backend runtime options
DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_ENABLED=true
CSRF_COOKIE_SECURE=false

# Optional governance toggles
RBAC_ENABLED=false
RBAC_ENFORCEMENT=false
TENANT_ENFORCEMENT_ENABLED=false
TENANT_API_KEY_BINDING_ENABLED=false

# Workflow approvals legacy response deprecation headers
WORKFLOW_APPROVALS_LEGACY_DEPRECATED_HEADER=approvals-legacy-format
WORKFLOW_APPROVALS_LEGACY_SUNSET=Wed, 31 Dec 2026 23:59:59 GMT

# Optional GPU selector for docker-compose.gpu.yml
CUDA_VISIBLE_DEVICES=all
