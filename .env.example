# Ports
FRONTEND_PORT=5173
BACKEND_PORT=8000

# Frontend build-time API base.
# Keep localhost:5173 so browser requests stay same-origin and nginx forwards to backend.
VITE_API_URL=http://localhost:5173

# Backend runtime options
DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_ENABLED=true
CSRF_COOKIE_SECURE=false
# Database:
# - Dev default uses SQLite at backend/data/platform.db
# - Production can switch to PostgreSQL via DATABASE_URL
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/openvitamin
# EXECUTION_KERNEL_DB_URL=postgresql+asyncpg://user:pass@host:5432/openvitamin
# DB_PATH=./backend/data/platform.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
# Redis inference cache (distributed)
INFERENCE_CACHE_ENABLED=true
INFERENCE_CACHE_REDIS_URL=redis://127.0.0.1:6379/0
INFERENCE_CACHE_PREFIX=openvitamin:inference
INFERENCE_CACHE_TTL_SECONDS=300
EMBEDDING_CACHE_TTL_SECONDS=86400
# Local runtime cache cap (LRU eviction when exceeded)
RUNTIME_MAX_CACHED_LOCAL_RUNTIMES=3
FILE_READ_ALLOWED_ROOTS=./data
PRODUCTION_FILE_READ_REQUIRED_ROOTS=./data
PRODUCTION_FILE_READ_ALLOWED_ROOTS=./data,/app/data,/app/backend/data

# Optional encrypted env support:
# 1) Store encrypted env in backend/.env.encrypted or project .env.encrypted
# 2) Inject OPENVITAMIN_ENV_ENCRYPTION_KEY at runtime (never commit it)
OPENVITAMIN_ENV_ENCRYPTION_KEY=

# Serper key injection options (pick one):
# WEB_SEARCH_SERPER_API_KEY=plain_text_key                           # dev only
# VAULT_WEB_SEARCH_SERPER_API_KEY=runtime_injected_secret            # preferred in production
# WEB_SEARCH_SERPER_API_KEY_FILE=/vault/secrets/serper_api_key       # file-based secret injection
# WEB_SEARCH_SERPER_API_KEY_ENCRYPTED=<fernet_token>                 # encrypted token

# Optional governance toggles
RBAC_ENABLED=false
RBAC_ENFORCEMENT=false
TENANT_ENFORCEMENT_ENABLED=false
TENANT_API_KEY_BINDING_ENABLED=false

# Workflow approvals legacy response deprecation headers
WORKFLOW_APPROVALS_LEGACY_DEPRECATED_HEADER=approvals-legacy-format
WORKFLOW_APPROVALS_LEGACY_SUNSET=Wed, 31 Dec 2026 23:59:59 GMT

# Optional GPU selector for docker-compose.gpu.yml
CUDA_VISIBLE_DEVICES=all
