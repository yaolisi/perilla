# =============================================================================
# 本地 AI 推理平台 - 环境变量示例
# 复制为 .env 并按需修改
#
# 推荐：通过 Platform Settings UI 配置（无需重启）
# 以下仅用于部署/CI 时覆盖默认值
# =============================================================================

# 本地模型根目录（LLM/VLM/Embedding/ASR/Perception 均在此下）
# LOCAL_MODEL_DIRECTORY=~/.local-ai/models/

# Workflow approvals legacy response deprecation headers（可按部署策略覆盖）
# WORKFLOW_APPROVALS_LEGACY_DEPRECATED_HEADER=approvals-legacy-format
# WORKFLOW_APPROVALS_LEGACY_SUNSET=Wed, 31 Dec 2026 23:59:59 GMT

# MCP Streamable HTTP：是否在 GET SSE 上收到服务端 JSON-RPC 时发布到事件总线（mcp.streamable.server_rpc，仅 method/键名摘要）
# MCP_HTTP_EMIT_SERVER_PUSH_EVENTS=true

# 其他配置见 config/settings.py
