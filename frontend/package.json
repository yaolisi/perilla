{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite --config vite.config.dev.ts",
    "audit:critical": "npm audit --audit-level=critical",
    "build": "vue-tsc -b && vite build --config vite.config.prod.ts",
    "preview": "vite preview --config vite.config.prod.ts",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:ci": "start-server-and-test dev http://127.0.0.1:5173 test:e2e"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@vue-flow/core": "^1.48.2",
    "@vueuse/core": "^14.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.0",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "lucide-vue-next": "^0.562.0",
    "markdown-it": "^14.1.0",
    "markdown-it-highlightjs": "^4.2.0",
    "markdown-it-katex": "^2.0.3",
    "mermaid": "^11.12.3",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.24",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.6",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.17",
    "cypress": "^15.14.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.35",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.1.4"
  }
}
