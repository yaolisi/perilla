{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3600
    },
    "containerPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": true
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "secretEnvFrom": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "optional": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "vmServiceScrape": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "pathType": { "type": "string" }
      },
      "additionalProperties": true
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        }
      },
      "additionalProperties": true
    },
    "horizontalPodAutoscaler": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "additionalProperties": true
        },
        "egress": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "priorityClassName": { "type": "string" },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "deploymentAnnotations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "preStopSleepSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 300
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
